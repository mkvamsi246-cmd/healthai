# =========================================
# HealthInsight AI — Environment Variables
# Copy this file to .env and fill in values
# =========================================

# --- Database ---
DATABASE_URL=mysql+pymysql://root:password@localhost:3306/healthinsight_ai
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=password
DB_NAME=healthinsight_ai

# --- JWT ---
SECRET_KEY=your-very-secure-secret-key-change-this-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# --- File Storage ---
UPLOAD_DIR=uploads
REPORTS_DIR=generated_reports
MAX_FILE_SIZE=10485760

# --- App ---
APP_NAME=HealthInsight AI
APP_VERSION=1.0.0
DEBUG=False
